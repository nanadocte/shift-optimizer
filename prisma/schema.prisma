generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int          @id @default(autoincrement())
  email      String       @unique
  name       String?
  password   String?
  role       Role         @default(EMPLOYE)
  job        String?
  contractHours Int @default(35)
  preference Preference[]
  contrainte Contrainte[]
  shift      Shift[]
}

enum Role {
  EMPLOYE
  ADMIN
}

model Preference {
  id        Int                      @id @default(autoincrement())
  type      PreferenceContrainteType @default(PONCTUAL)
  day       DayOfWeek?
  date      DateTime?
  startHour Int?
  endHour   Int?
  user      User                     @relation(fields: [userId], references: [id])
  userId    Int
  priority  Int @default(1)

}

enum PreferenceContrainteType {
  PONCTUAL
  RECURING
}

enum DayOfWeek {
  Lundi
  Mardi
  Mercredi
  Jeudi
  Vendredi
  Samedi
  Dimanche
}

model Contrainte {
  id        Int                      @id @default(autoincrement())
  type      PreferenceContrainteType @default(PONCTUAL)
  day       DayOfWeek?
  date      DateTime?
  startTime String
  endTime   String
  user      User                     @relation(fields: [userId], references: [id])
  userId    Int
  priority  Int @default(2)
}

model ShiftTemplate {
  id          Int       @id @default(autoincrement())
  type        PreferenceContrainteType @default(RECURING)
  day         DayOfWeek?
  date        DateTime?
  startTime   String
  endTime     String
  job         String
  quantityJob Int
  shift       Shift[]
}

model Shift {
  id              Int           @id @default(autoincrement())
  date            DateTime
  startTime       String
  endTime         String
  job             String
  user            User?         @relation(fields: [userId], references: [id])
  userId          Int?
  ShiftTemplate   ShiftTemplate? @relation(fields: [shiftTemplateId], references: [id])
  shiftTemplateId Int?
}
